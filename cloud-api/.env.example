# Local development example only. Do not put a real production token here.
PORT=8080
HEALTH_EXPORT_API_TOKEN=replace-with-local-dev-token
DRIVE_SYNC_API_TOKEN=replace-with-local-dev-token
HEALTH_EXPORT_DRIVE_FOLDER_ID=replace-with-google-drive-folder-id
DEFAULT_USER_ID=maya
ALLOWED_FIREBASE_UIDS=comma-separated-firebase-uids
ALLOW_DEV_READ_WITHOUT_AUTH=false
GOOGLE_CLOUD_PROJECT=
FIRESTORE_DATABASE_ID=(default)
